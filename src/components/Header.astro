---
const navItems = [
  { label: '首页', href: '/' },
  { label: '文章', href: '/posts' },
  { label: '相册', href: '/gallery' },
  { label: '关于', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-[var(--color-background)]/80 border-b border-[var(--color-border)]">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-serif font-bold tracking-tight hover:opacity-80 transition-opacity">
      后生仔
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-[var(--color-primary)]',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-muted-foreground)]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-[var(--color-muted)] transition-colors"
        aria-label="切换主题"
      >
        <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-[var(--color-muted)] transition-colors"
        aria-label="打开菜单"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)]">
    <ul class="px-6 py-4 space-y-3">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-2 text-sm font-medium transition-colors hover:text-[var(--color-primary)]',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-muted-foreground)]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
