---
interface Props {
  path: string;
}

const { path } = Astro.props;
---

<div id="tcomment" class="mt-16 pt-8 border-t border-[var(--color-border)]">
  <h2 class="text-2xl font-serif font-bold mb-8">评论</h2>
  <div id="twikoo-container"></div>
</div>

<script define:vars={{ path }}>
  // Load Twikoo
  function loadTwikoo() {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.6.39/dist/twikoo.all.min.js';
    script.onload = () => {
      twikoo.init({
        envId: 'https://your-twikoo.vercel.app', // Replace with your Twikoo envId
        el: '#twikoo-container',
        path: path,
        lang: 'zh-CN',
      });
    };
    document.head.appendChild(script);
  }

  // Load on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadTwikoo);
  } else {
    loadTwikoo();
  }
</script>

<style>
  /* Twikoo theme integration */
  :global(.twikoo) {
    --twikoo-font: var(--font-sans);
    --twikoo-border: var(--color-border);
    --twikoo-background: var(--color-card);
    --twikoo-text-color: var(--color-foreground);
  }
</style>
