---
---

<div id="music-player" class="fixed bottom-6 right-6 z-50">
  <button
    id="music-toggle"
    class="relative w-14 h-14 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300 group"
    title="播放/暂停音乐"
  >
    <!-- Rotating disc -->
    <div id="music-disc" class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center transition-transform duration-500">
      <div class="w-3 h-3 rounded-full bg-white"></div>
    </div>
    <!-- Play icon (shown when paused) -->
    <svg id="icon-play" class="absolute w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z"/>
    </svg>
    <!-- Pause icon (shown when playing) -->
    <svg id="icon-pause" class="absolute w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
    </svg>
  </button>
</div>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .music-playing #music-disc {
    animation: spin 3s linear infinite;
  }

  .music-paused #music-disc {
    animation: none;
  }

  .music-playing #music-status {
    animation: pulse 2s ease-in-out infinite;
  }
</style>

<script>
  const KEY_POS = '__bgm_pos';
  const KEY_STATE = '__bgm_playing';

  // Web Audio API — much lower latency
  const ctx = new (window.AudioContext || window.webkitAudioContext)();
  let source = null;
  let buffer = null;
  let startedAt = 0;
  let pausedAt = 0;
  let isPlaying = false;

  const toggle = document.getElementById('music-toggle');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');

  function setUI(playing) {
    isPlaying = playing;
    toggle.classList.toggle('music-playing', playing);
    toggle.classList.toggle('music-paused', !playing);
    iconPlay.classList.toggle('hidden', playing);
    iconPause.classList.toggle('hidden', !playing);
  }

  function play() {
    if (!buffer) return;
    // Resume context if suspended (browser autoplay policy)
    if (ctx.state === 'suspended') ctx.resume();

    source = ctx.createBufferSource();
    source.buffer = buffer;
    source.loop = true;
    source.connect(ctx.destination);
    source.start(0, pausedAt % buffer.duration);
    startedAt = ctx.currentTime - pausedAt;
    setUI(true);
  }

  function pause() {
    if (source) {
      source.stop();
      source.disconnect();
      source = null;
    }
    pausedAt = ctx.currentTime - startedAt;
    setUI(false);
  }

  // Fetch and decode audio once
  fetch('/bgm.mp3')
    .then(r => r.arrayBuffer())
    .then(data => ctx.decodeAudioData(data))
    .then(buf => {
      buffer = buf;

      // Restore from previous page
      const wasPlaying = sessionStorage.getItem(KEY_STATE) === '1';
      const savedPos = parseFloat(sessionStorage.getItem(KEY_POS) || '0');
      pausedAt = savedPos;

      if (wasPlaying) {
        play();
      } else {
        setUI(false);
      }
    });

  // Toggle — near instant
  toggle.addEventListener('click', () => {
    if (isPlaying) pause(); else play();
  });

  // Save state periodically + before unload
  function getPos() {
    return isPlaying ? (ctx.currentTime - startedAt) : pausedAt;
  }

  setInterval(() => {
    sessionStorage.setItem(KEY_POS, String(getPos()));
    sessionStorage.setItem(KEY_STATE, isPlaying ? '1' : '0');
  }, 1000);

  window.addEventListener('beforeunload', () => {
    sessionStorage.setItem(KEY_POS, String(getPos()));
    sessionStorage.setItem(KEY_STATE, isPlaying ? '1' : '0');
  });

  // First interaction fallback — resume suspended context
  document.addEventListener('click', () => {
    if (ctx.state === 'suspended') ctx.resume();
  }, { once: true });
</script>
