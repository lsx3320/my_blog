---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <section class="max-w-4xl mx-auto px-6 py-32 text-center">
    <h1 class="text-6xl md:text-8xl font-serif font-bold text-[var(--color-primary)] mb-6">404</h1>
    <p class="text-xl text-[var(--color-muted-foreground)] mb-8">
      抱歉，你访问的页面不存在
    </p>
    <a
      href="/"
      class="inline-flex items-center px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg font-medium text-sm hover:bg-[var(--color-primary-dark)] transition-colors"
    >
      返回首页
    </a>
  </section>
</BaseLayout>
