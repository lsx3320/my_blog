---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { label: '代码提交', value: '2,847', icon: 'code', suffix: '+' },
  { label: '咖啡续命', value: '1,024', icon: 'coffee', suffix: '杯' },
  { label: '深夜Debug', value: '365', icon: 'moon', suffix: '夜' },
  { label: '旅行城市', value: '12', icon: 'map', suffix: '座' },
];

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com', icon: 'github' },
  { name: '微信', url: '#wechat', icon: 'wechat' },
  { name: 'Email', url: '#copy-email', icon: 'email' },
];
---

<BaseLayout title="关于我">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <!-- Hero -->
    <div class="mb-16">
      <h1 class="text-3xl md:text-4xl font-serif font-bold mb-6">关于我</h1>
      <div class="flex flex-col md:flex-row gap-10 items-start">
        <img src="/gallery/mp3/image.png" alt="头像" class="w-32 h-32 rounded-full object-cover shrink-0 border-2 border-[var(--color-border)]" />
        <div>
          <p class="text-lg text-[var(--color-muted-foreground)] leading-relaxed mb-4">
            吾乃屌丝之楷模，以鄂西南做题家之出身，无惧寒微家境，只身勇赴汉城，偏皇家大湾一隅，事vibe coding之业，以八块腹肌之勇，推倒都市海归土肥圆。吾之爱情乃人间佳话，吾之事业乃励志传奇，如遇喷子，吾必将以黄金之劳砸其鼻梁，宾利之钥击其门齿！
          </p>
          <p class="text-lg text-[var(--color-muted-foreground)] leading-relaxed">
            吾信技术之道，可化凡俗为灵光，令柴米油盐皆生算法之美；亦信分享之力，可使孤知不孤，使一念之火，燃成万家星河。

吾以代码观世界，以迭代修人生；一行一commit，皆为进化之痕。

若问吾之所执，不过是：以技术渡己，以分享渡人。
          </p>
        </div>
      </div>
    </div>

    <!-- Fun Stats -->
    <div class="mb-16">
      <h2 class="text-2xl font-serif font-bold mb-8">日常数据</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map(stat => (
          <div class="group p-6 bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl text-center hover:border-[var(--color-primary)] hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center group-hover:scale-110 transition-transform">
              {stat.icon === 'code' && (
                <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              )}
              {stat.icon === 'coffee' && (
                <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 1v3M10 1v3M14 1v3" />
                </svg>
              )}
              {stat.icon === 'moon' && (
                <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
              )}
              {stat.icon === 'map' && (
                <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              )}
            </div>
            <div class="text-3xl font-bold text-[var(--color-foreground)] mb-1">
              {stat.value}<span class="text-lg text-[var(--color-primary)]">{stat.suffix}</span>
            </div>
            <div class="text-sm text-[var(--color-muted-foreground)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Social links -->
    <div>
      <h2 class="text-2xl font-serif font-bold mb-8">联系方式</h2>
      <div class="flex flex-wrap gap-4">
        {socialLinks.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-3 bg-[var(--color-card)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] hover:shadow-md transition-all"
          >
            {link.icon === 'github' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {link.icon === 'wechat' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.295.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .246-.11.246-.245 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zm-2.18 2.908c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.36 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.969-.982z"/>
              </svg>
            )}
            {link.icon === 'email' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            )}
            <span class="text-sm font-medium">{link.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WeChat QR Code Modal -->
  <div id="wechat-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="relative bg-[var(--color-card)] rounded-2xl shadow-2xl p-6 max-w-sm mx-4">
      <button id="close-modal" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-[var(--color-muted)] flex items-center justify-center hover:bg-[var(--color-border)] transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <h3 class="text-lg font-serif font-bold text-center mb-4">微信扫码添加</h3>
      <img src="/gallery/mp3/wx.png" alt="微信二维码" class="w-full rounded-lg" />
      <p class="text-sm text-[var(--color-muted-foreground)] text-center mt-4">扫描二维码添加微信好友</p>
    </div>
  </div>

  <script>
    // WeChat modal
    const wechatLink = document.querySelector('a[href="#wechat"]');
    const modal = document.getElementById('wechat-modal');
    const closeBtn = document.getElementById('close-modal');

    if (wechatLink && modal && closeBtn) {
      wechatLink.addEventListener('click', (e) => {
        e.preventDefault();
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });

      closeBtn.addEventListener('click', () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      });
    }

    // Email copy functionality
    const emailLink = document.querySelector('a[href="#copy-email"]');
    if (emailLink) {
      emailLink.addEventListener('click', async (e) => {
        e.preventDefault();
        try {
          await navigator.clipboard.writeText('15527759825@163.com');
          showToast('邮箱已复制到剪贴板');
        } catch (err) {
          // Fallback for older browsers
          const textarea = document.createElement('textarea');
          textarea.value = '15527759825@163.com';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          showToast('邮箱已复制到剪贴板');
        }
      });
    }

    // Toast notification
    function showToast(message) {
      const toast = document.createElement('div');
      toast.className = 'fixed bottom-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg shadow-lg text-sm font-medium transition-all duration-300 opacity-0 translate-y-2';
      toast.textContent = message;
      document.body.appendChild(toast);

      requestAnimationFrame(() => {
        toast.style.opacity = '1';
        toast.style.transform = 'translate(-50%, 0)';
      });

      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, 8px)';
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }
  </script>
</BaseLayout>
