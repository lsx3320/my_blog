---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const allMoments = await getCollection('moments');
const moments = allMoments.sort((a, b) => {
  const da = a.data.date?.valueOf() ?? Infinity;
  const db = b.data.date?.valueOf() ?? Infinity;
  if (da === db) return 0;
  if (da === Infinity) return -1;
  if (db === Infinity) return 1;
  return db - da;
});

const avatarUrl = '/gallery/ppyq/gougou.jpg';
const userName = '后生仔';
---

<BaseLayout title="朋友圈">
  <section class="max-w-2xl mx-auto px-4 py-16">
    <!-- Moments Feed -->
    <div class="space-y-6">
      {moments.map(async (moment) => {
        const { Content } = await render(moment);
        const formattedDate = moment.data.date?.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });

        return (
          <article class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-5 hover:shadow-md transition-all duration-300">
            <!-- User Info -->
            <div class="flex items-start gap-3 mb-4">
              <img src={avatarUrl} alt={userName} class="w-10 aspect-square rounded-full object-cover shrink-0 ring-2 ring-[var(--color-primary)]/20 shadow-md" />
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-[var(--color-foreground)]">{userName}</span>
                  {moment.data.location && (
                    <span class="text-xs text-[var(--color-muted-foreground)] flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {moment.data.location}
                    </span>
                  )}
                </div>
                {formattedDate && <time class="text-xs text-[var(--color-muted-foreground)]">{formattedDate}</time>}
              </div>
            </div>

            <!-- Content -->
            <div class="text-sm text-[var(--color-foreground)] leading-relaxed mb-4 pl-[52px]">
              <Content />
            </div>

            <!-- Images -->
            {moment.data.images && moment.data.images.length > 0 && (
              <div class="mb-4 pl-[52px]">
                {moment.data.images.length === 1 ? (
                  <div class="max-w-[280px] overflow-hidden rounded-lg cursor-pointer">
                    <img src={moment.data.images[0]} alt="" class="moment-img w-full h-auto rounded-lg hover:scale-[1.02] transition-transform duration-300" loading="lazy" />
                  </div>
                ) : (
                  <div class={`grid gap-2 ${
                    moment.data.images.length === 2 ? 'grid-cols-2' :
                    moment.data.images.length === 4 ? 'grid-cols-2' :
                    'grid-cols-3'
                  } max-w-[400px]`}>
                    {moment.data.images.map((img: string) => (
                      <div class="aspect-square overflow-hidden rounded-lg cursor-pointer">
                        <img src={img} alt="" class="moment-img w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            <!-- Actions -->
            <div class="flex items-center gap-4 pl-[52px] pt-3 border-t border-[var(--color-border)]">
              <button class="like-btn flex items-center gap-1.5 text-sm text-[var(--color-muted-foreground)] hover:text-[var(--color-primary)] transition-colors" data-likes={moment.data.likes}>
                <svg class="w-4 h-4 heart-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                <span class="like-count">{moment.data.likes}</span>
              </button>
            </div>
          </article>
        );
      })}
    </div>

    {moments.length === 0 && (
      <div class="text-center py-20">
        <p class="text-[var(--color-muted-foreground)]">暂无动态</p>
      </div>
    )}
  </section>
<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-black/90 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
  <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg scale-90 transition-transform duration-300" />
  <button id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<script>
  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');

  function openLightbox(src: string) {
    lightboxImg.src = src;
    lightbox?.classList.remove('opacity-0', 'pointer-events-none');
    lightboxImg.classList.remove('scale-90');
    lightboxImg.classList.add('scale-100');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.add('opacity-0', 'pointer-events-none');
    lightboxImg.classList.remove('scale-100');
    lightboxImg.classList.add('scale-90');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.moment-img').forEach(img => {
    img.addEventListener('click', () => openLightbox((img as HTMLImageElement).src));
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lightboxClose?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // Like button functionality
  document.querySelectorAll('.like-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const countEl = btn.querySelector('.like-count');
      const heartSvg = btn.querySelector('svg');
      let count = parseInt(countEl.textContent || '0');

      if (btn.classList.contains('liked')) {
        count--;
        btn.classList.remove('liked');
      } else {
        count++;
        btn.classList.add('liked');
        // Add animation
        heartSvg.classList.add('scale-125');
        setTimeout(() => heartSvg.classList.remove('scale-125'), 200);
      }

      countEl.textContent = String(count);
    });
  });
</script>

<style>
  .like-btn {
    -webkit-tap-highlight-color: transparent;
  }

  .heart-icon {
    transition: transform 0.2s ease;
    fill: none;
    stroke: currentColor;
  }

  .like-btn.liked {
    color: #ef4444;
  }

  .like-btn.liked .heart-icon {
    fill: #ef4444;
    stroke: #ef4444;
  }
</style>
